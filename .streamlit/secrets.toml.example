# Copy to secrets.toml (local) or set in Streamlit Cloud → App → Settings → Secrets.
# Do NOT commit secrets.toml.

# Admin password: only users who enter this can run "Execute scrape".
# If unset, everyone can run scrape (local dev).
SCRAPE_PASSWORD = "your-secret-password"

# Optional: cloud PostgreSQL so data persists when deployed.
# When set, app uses this instead of local SQLite (data/prices.db).
# Example (Supabase, Neon, etc.): postgresql://user:pass@host:5432/dbname
# DATABASE_URL = "postgresql://..."

# Optional: vision AI for Shapermint Amazon & Store price extraction. Use one of:
# ANTHROPIC_API_KEY = "sk-ant-..."   (preferred if set)
# OPENAI_API_KEY = "sk-..."
# USE_VISION_PRICES = "1"

# Optional: US proxy for Amazon scraper (so Amazon shows USD instead of local currency e.g. ARS).
# Precedence: AMAZON_PROXY_URL, then HTTPS_PROXY, then HTTP_PROXY.
# AMAZON_PROXY_URL = "http://us-proxy.example.com:8080"
# If the proxy requires auth, set:
# AMAZON_PROXY_USER = "your-username"
# AMAZON_PROXY_PASSWORD = "your-password"
# Or put credentials in the URL: AMAZON_PROXY_URL = "http://user:pass@host:8080"
