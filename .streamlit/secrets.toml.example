# Copy to secrets.toml (local) or set in Streamlit Cloud → App → Settings → Secrets.
# Do NOT commit secrets.toml.

# Admin password: only users who enter this can run "Execute scrape".
# If unset, everyone can run scrape (local dev).
SCRAPE_PASSWORD = "your-secret-password"

# Optional: cloud PostgreSQL so data persists when deployed.
# When set, app uses this instead of local SQLite (data/prices.db).
# Example (Supabase, Neon, etc.): postgresql://user:pass@host:5432/dbname
# DATABASE_URL = "postgresql://..."
